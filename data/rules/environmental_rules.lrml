<?xml version="1.0" encoding="UTF-8"?>
<!--
  Pravila za krivicna dela protiv zivotne sredine (KZ RS, cl. 260-268).
  DR-DEVICE LegalRuleML dijalekt. GENERISANO iz build_environmental_lrml.py.
  Celina 3 (predstavljanje) + Celina 5 (rasudjivanje alatom dr-device).
  14 pravnih normi (cl. 260-268); ILI-uslovi su razbijeni na vise pravila.
-->
<lrml:LegalRuleML
  xmlns:lrml="http://docs.oasis-open.org/legalruleml/ns/v1.0/"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:ruleml="http://ruleml.org/spec">

  <lrml:Statements>

    <!-- ===================== PRAVILA (cl. 260-268) ===================== -->

    <!-- cl. 260 st. 1 — Zagadjenje, osnovni oblik (umisljaj) -->
    <lrml:PrescriptiveStatement key="ps_260_1_1">
      <ruleml:Rule key=":rule_260_1_1" closure="universal" strength="defeasible">
        <ruleml:if>
          <ruleml:And>
            <ruleml:Atom>
              <ruleml:Rel iri="lc:violatedEnvironmentalRegs"/>
              <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
              <ruleml:Data xsi:type="xs:string">true</ruleml:Data>
            </ruleml:Atom>
            <ruleml:Atom>
              <ruleml:Rel iri="lc:pollutionExtent"/>
              <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
              <ruleml:Data xsi:type="xs:string">VECA_MERA</ruleml:Data>
            </ruleml:Atom>
            <ruleml:Atom>
              <ruleml:Rel iri="lc:intent"/>
              <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
              <ruleml:Data xsi:type="xs:string">UMISLJAJ</ruleml:Data>
            </ruleml:Atom>
          </ruleml:And>
        </ruleml:if>
        <ruleml:then>
          <ruleml:Atom>
            <ruleml:Rel>violates_260_1</ruleml:Rel>
            <ruleml:Var type=":defendant">Defendant</ruleml:Var>
          </ruleml:Atom>
        </ruleml:then>
      </ruleml:Rule>
    </lrml:PrescriptiveStatement>

