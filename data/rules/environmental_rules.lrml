        </ruleml:then>
      </ruleml:Rule>
    </lrml:PrescriptiveStatement>

    <!-- ============================================================ -->
    <!-- R13: Nedozvoljena izgradnja nuklearnih postrojenja (čl. 267) -->
    <!--                                                              -->
    <!-- AKO je odobrio/pristupio izgradnji nuklearnog postrojenja    -->
    <!-- ONDA krši čl. 267                                            -->
    <!--   raspon kazne: 6m - 60m (6 meseci do 5 godina)              -->
    <!-- ============================================================ -->
    <lrml:PrescriptiveStatement key="rule_R13">
      <ruleml:Rule>
        <ruleml:if>
