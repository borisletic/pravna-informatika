            </ruleml:Atom>
            <ruleml:Atom>
              <ruleml:Rel>sentenceRange</ruleml:Rel>
              <ruleml:Var>person</ruleml:Var>
              <ruleml:Ind>12</ruleml:Ind>
              <ruleml:Ind>96</ruleml:Ind>
            </ruleml:Atom>
          </ruleml:And>
        </ruleml:then>
      </ruleml:Rule>
    </lrml:PrescriptiveStatement>

    <!-- ============================================================ -->
    <!-- R12: Opasne materije - organizovanje vršenja (čl. 266 st. 5) -->
    <!--                                                              -->
    <!-- AKO je organizovao vršenje dela sa opasnim materijama        -->
    <!-- ONDA krši čl. 266 st. 5                                      -->
    <!--   raspon kazne: 36m - 120m (3 do 10 godina)                  -->
    <!-- ============================================================ -->
    <lrml:PrescriptiveStatement key="rule_R12">
      <ruleml:Rule>
        <ruleml:if>
          <ruleml:And>
            <ruleml:Atom>
              <ruleml:Rel>dangerousSubstanceAction</ruleml:Rel>
