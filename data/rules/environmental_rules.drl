package rs.ftn.pi.reasoning.rule;

// ============================================================
// PRAVILA ZA KRIVIČNA DELA PROTIV ŽIVOTNE SREDINE
// KZ Republike Srbije, čl. 260-268
//
// VLASNIK: Član 1 (Legal Modeling)
// CELINA: 5
//
// FIX v2: Dodato insert() u then-blok da bi se forward chaining radio.
// Bez ovoga, R3 i R4 nikad ne pucaju jer Drools ne vidi
// DroolsConclusion činjenice koje su druga pravila proizvela.
// ============================================================

import rs.ftn.pi.model.CaseFacts;
import rs.ftn.pi.reasoning.rule.DroolsConclusion;

global java.util.List conclusions;
global java.util.List trace;

// ============================================================
// HELPER: ispaljuje zaključak (lista + Drools sesija)
// ============================================================
function DroolsConclusion makeViolation(String ruleId, String articleEId,
                                        int minMonths, int maxMonths,
                                        java.util.List conclusions,
                                        java.util.List trace) {
    DroolsConclusion c = new DroolsConclusion(ruleId, articleEId, minMonths, maxMonths);
    conclusions.add(c);
    trace.add(ruleId + " -> violates(" + articleEId + "), sentenceRange(" +
             minMonths + "m, " + maxMonths + "m)");
    return c;
}

// ============================================================
// R1: Zagađenje životne sredine - osnovni oblik (čl. 260 st. 1)
// ============================================================
rule "R1_pollution_basic_intent"
    salience 100
when
    facts : CaseFacts(
        facts["violatedEnvironmentalRegs"] == true,
        facts["pollutionTarget"] != null,
        (facts["pollutionExtent"] == "VECA_MERA" || facts["pollutionScope"] == "SIRI_PROSTOR"),
        facts["intent"] == "UMISLJAJ"
    )
then
    DroolsConclusion c = makeViolation("R1", "art_260__para_1", 6, 60, conclusions, trace);
    insert(c);   // omogucava da R3 vidi ovaj zakljucak
end

// ============================================================
// R2: Zagađenje iz nehata (čl. 260 st. 2)
// ============================================================
rule "R2_pollution_negligence"
    salience 100
when
    facts : CaseFacts(
        facts["violatedEnvironmentalRegs"] == true,
        facts["pollutionTarget"] != null,
        (facts["pollutionExtent"] == "VECA_MERA" || facts["pollutionScope"] == "SIRI_PROSTOR"),
        facts["intent"] == "NEHAT"
    )
then
    DroolsConclusion c = makeViolation("R2", "art_260__para_2", 0, 24, conclusions, trace);
    insert(c);   // omogucava da R4 vidi ovaj zakljucak
end

// ============================================================
// R3: Kvalifikovani oblik sa umišljajem (čl. 260 st. 3)
// Lanca se sa R1 - aktivira se kada R1 ispali DroolsConclusion u sesiju.
// ============================================================
rule "R3_pollution_qualified_intent"
    salience 90
when
    DroolsConclusion(articleEId == "art_260__para_1")
    facts : CaseFacts(
        (facts["ecologicalDamage"] == "VELIKIH_RAZMERA" ||
         facts["damageRemovalDifficulty"] == "ZAHTEVNO")
    )
then
    DroolsConclusion c = makeViolation("R3", "art_260__para_3", 12, 96, conclusions, trace);
    insert(c);
end

// ============================================================
// R4: Kvalifikovani oblik iz nehata (čl. 260 st. 4)
// ============================================================
rule "R4_pollution_qualified_negligence"
    salience 90
when
    DroolsConclusion(articleEId == "art_260__para_2")
    facts : CaseFacts(
        (facts["ecologicalDamage"] == "VELIKIH_RAZMERA" ||
         facts["damageRemovalDifficulty"] == "ZAHTEVNO")
    )
then
    DroolsConclusion c = makeViolation("R4", "art_260__para_4", 6, 60, conclusions, trace);
    insert(c);
end

// ============================================================
// R5: Nepreduzimanje mera zaštite (čl. 261 st. 1)
// ============================================================
rule "R5_failed_protective_measures"
    salience 100
when
    facts : CaseFacts(
        (facts["perpetratorType"] == "SLUZBENO_LICE" || facts["perpetratorType"] == "ODGOVORNO_LICE"),
        facts["failedToTakeProtectiveMeasures"] == true
    )
then
    DroolsConclusion c = makeViolation("R5", "art_261__para_1", 0, 36, conclusions, trace);
    insert(c);
end

// ============================================================
// R6: Protivpravna izgradnja (čl. 262 st. 1)
// ============================================================
rule "R6_unauthorized_construction"
    salience 100
when
    facts : CaseFacts(
        (facts["perpetratorType"] == "SLUZBENO_LICE" || facts["perpetratorType"] == "ODGOVORNO_LICE"),
        facts["unauthorizedConstruction"] == true,
        (facts["pollutionExtent"] == "VECA_MERA" || facts["pollutionScope"] == "SIRI_PROSTOR")
    )
then
    DroolsConclusion c = makeViolation("R6", "art_262__para_1", 6, 60, conclusions, trace);
    insert(c);
end

// ============================================================
// R7: Oštećenje objekata zaštite (čl. 263 st. 1)
// ============================================================
rule "R7_damaged_protection_equipment"
    salience 100
when
    facts : CaseFacts(facts["damagedProtectionEquipment"] == true)
then
    DroolsConclusion c = makeViolation("R7", "art_263__para_1", 0, 36, conclusions, trace);
    insert(c);
end

// ============================================================
// R8: Uništenje zaštićenog prirodnog dobra (čl. 265 st. 1)
// ============================================================
rule "R8_destroyed_protected_asset"
    salience 100
when
    facts : CaseFacts(facts["destroyedProtectedNaturalAsset"] == true)
then
    DroolsConclusion c = makeViolation("R8", "art_265__para_1", 6, 60, conclusions, trace);
    insert(c);
end

// ============================================================
// R9: Iznošenje zaštićene vrste (čl. 265 st. 3)
// ============================================================
rule "R9_illegal_species_traffic"
    salience 100
when
    facts : CaseFacts(facts["illegalSpeciesTraffic"] == true)
then
    DroolsConclusion c = makeViolation("R9", "art_265__para_3", 3, 36, conclusions, trace);
    insert(c);
end

// ============================================================
// R10: Opasne materije - osnovni oblik (čl. 266 st. 1)
// ============================================================
rule "R10_dangerous_substance_basic"
    salience 100
when
    facts : CaseFacts(
        facts["dangerousSubstanceAction"] == true,
        facts["officialPositionAbuse"] != true,
        facts["organizesCrime"] != true
    )
then
    DroolsConclusion c = makeViolation("R10", "art_266__para_1", 6, 60, conclusions, trace);
    insert(c);
end

// ============================================================
// R11: Opasne materije + zloupotreba sluzbenog polozaja (čl. 266 st. 2)
// ============================================================
rule "R11_dangerous_substance_official_abuse"
    salience 110
when
    facts : CaseFacts(
        facts["dangerousSubstanceAction"] == true,
        facts["officialPositionAbuse"] == true
    )
then
    DroolsConclusion c = makeViolation("R11", "art_266__para_2", 12, 96, conclusions, trace);
    insert(c);
end

// ============================================================
// R12: Opasne materije - organizovanje (čl. 266 st. 5)
// ============================================================
rule "R12_dangerous_substance_organizer"
    salience 120
when
    facts : CaseFacts(
        facts["dangerousSubstanceAction"] == true,
        facts["organizesCrime"] == true
    )
then
    DroolsConclusion c = makeViolation("R12", "art_266__para_5", 36, 120, conclusions, trace);
    insert(c);
end

// ============================================================
// R13: Nuklearna postrojenja (čl. 267)
// ============================================================
rule "R13_unauthorized_nuclear"
    salience 100
when
    facts : CaseFacts(facts["unauthorizedNuclearFacility"] == true)
then
    DroolsConclusion c = makeViolation("R13", "art_267__para_1", 6, 60, conclusions, trace);
    insert(c);
end

// ============================================================
// R14: Uskraćivanje informacija (čl. 268)
// ============================================================
rule "R14_denied_environmental_info"
    salience 100
when
    facts : CaseFacts(facts["deniedEnvironmentalInfo"] == true)
then
    DroolsConclusion c = makeViolation("R14", "art_268__para_1", 0, 12, conclusions, trace);
    insert(c);
end
